---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
---

<Layout title="Bandung BRT Shelter Guide">
    <main class="relative w-screen h-screen overflow-hidden">
        <div class="absolute inset-0 z-0">
            <Map />
        </div>

        <div
            class="absolute top-4 left-12 z-[1000] bg-white/95 backdrop-blur-sm rounded-lg shadow-lg p-6 max-w-md"
        >
            <h1 class="text-3xl font-bold mb-2">
                Bandung BRT: Off-Corridor Shelter Map
            </h1>
            <p class="text-gray-700 text-lg">
                Visualizing the 2026 construction phase based on the <a
                    href="https://transportforbandung.org/assets/pdf/Land%20Acquisition%20and%20Resettlement%20Action%20Plan%20BBMA%20BRT.pdf"
                    class="text-blue-600 hover:underline"
                    >Supplementary LARAP December 2025</a
                >.
            </p>
        </div>
    </main>
</Layout>
